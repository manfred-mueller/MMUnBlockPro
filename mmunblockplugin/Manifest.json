{
  "manifest_version": 3,
  "name": "MMUnblock Pro",
  "version": "1.1",
  "description": "Entsperrt Downloads interaktiv oder per Whitelist an jedem Speicherort.",
  "permissions": [
    "downloads",
    "nativeMessaging",
    "notifications",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "@mmunblockpro",
      "data_collection_permissions": {
        "required": [
          "none"
       ]
      }
    }
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}